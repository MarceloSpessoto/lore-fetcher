# Patch source: "imap" (default) or "lore"
PATCH_SOURCE=imap
LORE_BASE_URL=https://lore.kernel.org/
LORE_SUBSYSTEM=all

# IMAP mailing list (used when PATCH_SOURCE=imap)
IMAP_SERVER=imap.gmail.com:993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_TLS=true

GITLAB_URL=https://gitlab.freedesktop.org
GITLAB_PROJECT_ID=
GITLAB_TRIGGER_TOKEN=
GITLAB_REF=
